cor_fd <- avg_forcedeck |> select(!`Athlete Id`) |> cor()
```

```{r}
miss_var_summary(data)
```

```{r}
#Forcedeck model
fd_mod1 <- lm(`Peak Power / BM [W/kg]` ~ 
               rightMaxForce + max_peak_power +
               `innerRightMaxForce_Hip AD/AB - 60` + 
               `innerRightMaxForce_Shoulder IR/ER - Custom` + body_weight, data = scaled_data)

summary(fd_mod1)

fd_mod2 <- lm(`RSI-modified [m/s]` ~ 
               rightMaxForce + max_peak_power +
               `innerRightMaxForce_Hip AD/AB - 60` + 
               `innerRightMaxForce_Shoulder IR/ER - Custom` + body_weight, data = scaled_data)

summary(fd_mod2)
```

NordBord - Left/Right Max Force $$N$$ - maxforce_asymmetry

Force Deck - RSI-modified $$m/s$$ or Peak Power / BM $$W/kg$$ - Eccentric Deceleration RFD Asymmetry $$% L,R$$ - Landing Impulse (Asymmetry) $$% L,R$$ - Peak Landing Force Asymmetry $$% L,R$$

Force Frame - Outer/Inner Left/Right Max Force $$N$$ - innerMaxForce_Asymmetry_hips - outerMaxForce_Asymmetry_hips - innerMaxForce_Asymmetry_shoulders - outerMaxForce_Asymmetry_hips

Perch - Max Peak Power $$W$$

```{r}
#Force Frame model
ff_mod_hip <- lm(`innerRightMaxForce_Hip AD/AB - 60` ~
                `Peak Power / BM [W/kg]` + rightMaxForce + max_peak_power +
                `innerRightMaxForce_Shoulder IR/ER - Custom` + body_weight, data = scaled_data)
 
summary(ff_mod_hip)

ff_mod_shoulder <- lm(`innerRightMaxForce_Shoulder IR/ER - Custom` ~
                `Peak Power / BM [W/kg]` + rightMaxForce + max_peak_power +
                `innerRightMaxForce_Hip AD/AB - 60` + body_weight, data = scaled_data)
 
summary(ff_mod_shoulder)


## Using RSI instead of peak power
ff_mod_hip <- lm(`innerRightMaxForce_Hip AD/AB - 60` ~
                `RSI-modified [m/s]` + rightMaxForce + max_peak_power +
                `innerRightMaxForce_Shoulder IR/ER - Custom` + body_weight, data = scaled_data)
 
summary(ff_mod_hip)

ff_mod_shoulder <- lm(`innerRightMaxForce_Shoulder IR/ER - Custom` ~
                `RSI-modified [m/s]` + rightMaxForce + max_peak_power +
                `innerRightMaxForce_Hip AD/AB - 60` + body_weight, data = scaled_data)
 
summary(ff_mod_shoulder)
```

```{r}
#Nordbord Model
nb_mod <- lm(rightMaxForce ~
                `RSI-modified [m/s]` + `innerRightMaxForce_Shoulder IR/ER - Custom` + 
                  max_peak_power + body_weight +
                `innerRightMaxForce_Hip AD/AB - 60` + body_weight, data = data)
 
summary(nb_mod)
```

Perch:

```{r}
p_mod <- lm(max_peak_power ~
               `RSI-modified [m/s]` + `innerRightMaxForce_Shoulder IR/ER - Custom` + 
                 rightMaxForce + body_weight +
               `innerRightMaxForce_Hip AD/AB - 60`, data = data)

summary(p_mod)
```

```{r}
p_fd_mod <- lm(avg_peak_power ~
               `RSI-modified [m/s]` + body_weight, data = scaled_data)

summary(p_fd_mod)
```

```{r}
test_p_fd_mod <- lm(avg_peak_power ~ 
               `RSI-modified [m/s]` + body_weight, data = scaled_data)

summary(test_p_fd_mod)
```

## Asymmetries between L and R metrics to predict performance

For each metric of interest, we can use both raw metrics and differences to predict performance, assuming heteroskedascisity plots do not show major issues.

NordBord - Left/Right Max Force $$N$$ - maxforce_asymmetry

Force Deck - RSI-modified $$m/s$$ or Peak Power / BM $$W/kg$$ - Eccentric Deceleration RFD Asymmetry $$% L,R$$ - Landing Impulse (Asymmetry) $$% L,R$$ - Peak Landing Force Asymmetry $$% L,R$$

Force Frame - Outer/Inner Left/Right Max Force $$N$$ - innerMaxForce_Asymmetry_hips - outerMaxForce_Asymmetry_hips - innerMaxForce_Asymmetry_shoulders - outerMaxForce_Asymmetry_hips

Perch - Max Peak Power $$W$$

```{r}
# Nordbord
summary(lm( rightMaxForce ~ `Landing Impulse (Asymmetry) [% L,R]`+
                `Peak Landing Force Asymmetry [% L,R]`+
                `Eccentric Deceleration RFD Asymmetry [% L,R]`+ 
                innerMaxForce_Asymmetry_hips + 
                innerMaxForce_Asymmetry_shoulders + 
                outerMaxForce_Asymmetry_hips + 
                outerMaxForce_Asymmetry_shoulders + body_weight, data = data))
```

```{r}
# Perch
summary(lm( max_peak_power ~ `Landing Impulse (Asymmetry) [% L,R]`+
                `Peak Landing Force Asymmetry [% L,R]`+
                `Eccentric Deceleration RFD Asymmetry [% L,R]`+ 
                maxforce_asymmetry + 
                innerMaxForce_Asymmetry_hips + 
                innerMaxForce_Asymmetry_shoulders + 
                outerMaxForce_Asymmetry_hips + 
                outerMaxForce_Asymmetry_shoulders + body_weight, data = data))
```

```{r}
# Force Deck
summary(lm( `RSI-modified [m/s]` ~ maxforce_asymmetry + 
                innerMaxForce_Asymmetry_hips + 
                innerMaxForce_Asymmetry_shoulders + 
                outerMaxForce_Asymmetry_hips + 
                outerMaxForce_Asymmetry_shoulders + body_weight, data = data))
```

```{r}
#Force Frame
summary(lm(`innerRightMaxForce_Hip AD/AB - 60` ~ 
             `Landing Impulse (Asymmetry) [% L,R]`+
                `Peak Landing Force Asymmetry [% L,R]`+
                `Eccentric Deceleration RFD Asymmetry [% L,R]`+ 
                maxforce_asymmetry + 
                innerMaxForce_Asymmetry_shoulders + 
                outerMaxForce_Asymmetry_shoulders + body_weight, data = data))

summary(lm(`innerRightMaxForce_Shoulder IR/ER - Custom` ~ 
             `Landing Impulse (Asymmetry) [% L,R]`+
                `Peak Landing Force Asymmetry [% L,R]`+
                `Eccentric Deceleration RFD Asymmetry [% L,R]`+ 
                maxforce_asymmetry + 
                innerMaxForce_Asymmetry_hips + 
                outerMaxForce_Asymmetry_hips + body_weight, data = data))
```
