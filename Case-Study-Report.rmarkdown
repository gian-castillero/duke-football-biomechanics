```{r, packages}
library(readxl)
library(tidyverse)
library(dplyr)
library(ggplot2)
library(tidyr)
library(knitr)
library(lubridate)
library(naniar)
library(lme4)
```

```{r, load-data}
forcedeck <- read_excel("data/forcedeck.xlsx")
forceframe <- read_excel("data/forceframe.xlsx")
nordbord <- read_excel("data/nordbord.xlsx")
perch <- read_excel("data/perch.xlsx")
```

```{r}
# Select blue and green columns from spreadhseet
forcedeck <- forcedeck |>
  select(`Athlete Id`, `Test Date`, `Body Weight [kg]`, 
         `Peak Power / BM [W/kg]`, `RSI-modified [m/s]`, 
         `Countermovement Depth [cm]`, `Eccentric Braking Impulse [N s]`,
         `Concentric Duration [ms]`, 
         `Eccentric Deceleration RFD / BM [N/s/kg]`, 
         `Jump Height (Imp-Mom) [cm]`, 
         `Eccentric Deceleration RFD Asymmetry [% L,R]`, 
         `Concentric Impulse-100ms [N s]`, `Eccentric Duration [ms]`,
         `Eccentric Peak Velocity [m/s]`, `Jump Height (Flight Time) [cm]`,
         `Landing Impulse [N s]`, `Peak Landing Force / BM [N/kg]`, 
         `Landing Impulse (Asymmetry) [% L,R]`, 
         `Peak Landing Force Asymmetry [% L,R]`, 
         `Concentric Impulse (Left) [N s]`, 
         `Concentric Impulse (Right) [N s]`, 
         `Eccentric Braking Impulse (Left) [N s]`, 
         `Eccentric Braking Impulse (Right) [N s]`, 
         `Eccentric Deceleration RFD (Left) [N/s]`, 
         `Eccentric Deceleration RFD (Right) [N/s]`, 
         `Landing Impulse (Left) [N s]`, `Landing Impulse (Right) [N s]`,
         `Peak Landing Force (Left) [N]`, `Peak Landing Force (Right) [N]`)

forceframe <- forceframe |>
  select(athleteId, testDateUtc, innerLeftMaxForce, innerRightMaxForce,
         outerLeftMaxForce, outerRightMaxForce, testPositionName)

nordbord <- nordbord |>
            select(athleteId, testDateUtc, leftMaxForce, rightMaxForce)

perch <- perch |> 
         select(name, start_time, avg_ecc_mean_power, avg_ecc_mean_velocity, 
                avg_mean_power, avg_mean_velocity, avg_peak_power, 
                avg_peak_velocity, max_ecc_mean_power, max_ecc_mean_velocity,                
                max_mean_velocity, max_peak_power, max_peak_velocity, 
                pct_1rm, start_time, weight)
```

```{r}
# Separate date and time
forcedeck <- forcedeck |>
  separate_wider_delim(cols = `Test Date`, delim = " ", names = c("Date", "Time"))

forceframe <- forceframe |>
  separate_wider_delim(cols = testDateUtc, delim = "T", names = c("Date", "Time"))

nordbord <- nordbord |>
  separate_wider_delim(cols = testDateUtc, delim = "T", names = c("Date", "Time")) 

perch <- perch |>
  mutate(date = as.POSIXct(start_time)) |>
  separate_wider_delim(cols = date, delim = " ", names = c("Date", "Time")) 
```

```{r}
# Format dates
forcedeck$Date <- ymd(forcedeck$Date)
forceframe$Date <- ymd(forceframe$Date)
nordbord$Date <- ymd(nordbord$Date)
```

